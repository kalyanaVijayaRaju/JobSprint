# Application Settings
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database Connection
MONGODB_URI=mongodb://localhost:27017/jobsprint

# JWT Secrets
JWT_SECRET=replace_with_a_random_secret_of_at_least_32_characters
JWT_EXPIRES_IN=24h

# Free/local infrastructure defaults
# These are optional for the current backend, but they define the adapters we
# will use as the project grows. No paid provider API key is required.
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
EMAIL_PROVIDER=console
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage
PUBLIC_ASSET_BASE_URL=http://localhost:5000/assets
