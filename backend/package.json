{
  "name": "jobsprint-backend",
  "version": "1.0.0",
  "description": "Backend API for JobSprint Job Portal",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "check": "node --check src/server.js && node --check src/app.js",
    "expire-jobs": "node src/tasks/expireOverdueJobs.js",
    "test": "node --test",
    "seed": "node scripts/seed/index.js",
    "seed:clear": "node scripts/seed/clear.js",
    "seed:companies": "node scripts/seed/index.js --only=companies",
    "seed:candidates": "node scripts/seed/index.js --only=candidates",
    "seed:jobs": "node scripts/seed/index.js --only=jobs",
    "seed:applications": "node scripts/seed/index.js --only=applications"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
